# UNIMOVE-DZ Environment Variables
# Copy this file to .env.local and fill in your actual values

# Application
NEXT_PUBLIC_APP_NAME=UNIMOVE-DZ

# Firebase Configuration
# Get these from Firebase Console: https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Twilio Configuration (Alternative to Firebase)
# Get these from Twilio Console: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# SMS Provider Selection
# Options: firebase, twilio
SMS_PROVIDER=firebase
